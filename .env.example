# Telegram BotFather token. Change token here, then restart the container.
BOT_TOKEN=123456789:replace_me

# Your personal Telegram user_id. Only this user can use private commands.
OWNER_USER_ID=123456789

# The one fixed group/supergroup that receives scheduled daily/weekly/monthly reports.
REPORT_CHAT_ID=-1001234567890

# Optional channel that receives and pins the same scheduled reports. Leave empty to disable.
REPORT_CHANNEL_ID=-1002222222222

# Source channels whose posts should be copied to your private chat.
# Prefer numeric -100 IDs for private channels. Usernames also work for public channels.
SOURCE_CHANNEL_IDS=-1001111111111,@your_public_channel

# Runtime data.
DATA_PATH=/app/data/assistant.sqlite3
TIMEZONE=Asia/Shanghai

# Long polling.
POLL_TIMEOUT=25
POLL_INTERVAL=1

# Reports are sent at 00:00 by default:
# daily every day, weekly every Monday, monthly on day 1.
REPORT_HOUR=0
REPORT_MINUTE=0

# If someone adds the bot to an unauthorized group/channel, leave it.
UNAUTHORIZED_GROUP_ACTION=leave

# Set to 1 only for the very first run if you want to drop old queued bot updates.
STARTUP_DROP_PENDING_UPDATES=0
